# ===========================================
# Meridian Wealth Advisors - Backend Environment
# Copy this file to .env and fill in your values
# ===========================================

# Server
NODE_ENV=development
PORT=3001

# PostgreSQL
POSTGRES_DB=meridian_wealth
POSTGRES_USER=meridian
POSTGRES_PASSWORD=your-secure-password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://meridian:your-secure-password@localhost:5432/meridian_wealth?schema=public

# pgAdmin
PGADMIN_EMAIL=admin@meridianwealth.com
PGADMIN_PASSWORD=your-pgadmin-password
PGADMIN_PORT=5050

# JWT Authentication
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Anthropic Claude SDK
ANTHROPIC_API_KEY=your-anthropic-api-key

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug
